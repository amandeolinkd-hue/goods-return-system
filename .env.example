# ---- Copy this file to .env.local and fill in real values ----

# Neon Postgres connection string.
# Neon Console -> your project -> "Connect" -> copy the connection string.
# Use the POOLED string (host contains "-pooler") for the app.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js session secret. Generate one with:  npx auth secret
AUTH_SECRET=""

# Vercel Blob token (added later, in the deploy phase).
# Vercel dashboard -> Storage -> Blob -> connect to project -> copy token.
BLOB_READ_WRITE_TOKEN=""
